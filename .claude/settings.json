{
  "permissions": {
    "allow": [
      "Search",
      "Read",
      "WebFetch",
      "Batch(ls:*)",
      "Bash(cat:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(sed:*)",
      "Bash(awk:*)",
      "Bash(python:*)",
      "Bash(parallel:*)",
      "Bash(uv:*)",
      "Bash(git log:*)",
      "Bash(cd:*)",
      "Bash(echo:*)"
    ],
    "deny": []
  },
  "statusLine": {
    "type": "command",
    "command": "input=$(cat); printf '%s@%s:%s [%s]' \"$(whoami)\" \"$(hostname -s)\" \"$(echo \"$input\" | jq -r '.workspace.current_dir' | sed 's|.*/||')\" \"$(echo \"$input\" | jq -r '.model.display_name')\""
  }
}