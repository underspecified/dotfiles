{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash(awk *)",
      "Bash(cat *)",
      "Bash(cd *)",
      "Bash(echo *)",
      "Bash(find *)",
      "Bash(git log *)",
      "Bash(grep *)",
      "Bash(head)",
      "Bash(head *)",
      "Bash(ls *)",
      "Bash(open *)",
      "Bash(printf *)",
      "Bash(tail)",
      "Bash(tail *)",
      "Bash(sed *)",
      "Bash(wc *)",
      "Bash(curl *)",
      "Bash(git add *)",
      "Bash(git check-ignore *)",
      "Bash(git commit *)",
      "Bash(git pull)",
      "Bash(git pull *)",
      "Bash(git status)",
      "Bash(git status *)",
      "Bash(ruff check *)",
      "WebSearch",
      "mcp__plugin_context7_context7__query-docs",
      "mcp__plugin_context7_context7__resolve-library-id",
      "Edit(~/haru.md/**)",
      "Read",
      "Read(~/haru.md/**)",
      "Search",
      "TaskCreate",
      "TaskGet",
      "TaskList",
      "TaskOutput",
      "TaskStop",
      "TaskUpdate",
      "WebFetch",
      "Write(~/haru.md/**)"
    ],
    "deny": []
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/eric/.claude/hooks/nag_docs.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "if [[ \"$CLAUDE_FILE_PATH\" == *.py ]]; then ruff format \"$CLAUDE_FILE_PATH\" 2>/dev/null || true; fi"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "if [[ \"$CLAUDE_FILE_PATH\" == *.md || \"$CLAUDE_FILE_PATH\" == *.qmd ]]; then rumdl check --fix --config ~/.rumdl.toml \"$CLAUDE_FILE_PATH\" 2>/dev/null || true; fi"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "node /Users/eric/.claude/claude-limitline-fork/dist/index.js"
  },
  "enabledPlugins": {
    "pyright-lsp@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "hookify@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": false,
    "security-guidance@claude-plugins-official": true,
    "explanatory-output-style@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true
  },
  "alwaysThinkingEnabled": true
}
