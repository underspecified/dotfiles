{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Edit",
      "Edit(~/haru.md/**)",
      "Read",
      "Read(*)",
      "Read(/Users/eric/Library/CloudStorage/OneDrive-HRI-JP/HRI-JP/projects/**)",
      "Read(~/git/**)",
      "Read(~/haru.md/**)",
      "Read(~/projects/**)",
      "Search",
      "TaskCreate",
      "TaskGet",
      "TaskList",
      "TaskOutput",
      "TaskStop",
      "TaskUpdate",
      "WebFetch",
      "WebSearch",
      "Write",
      "Write(~/git/**)",
      "Write(~/haru.md/**)",
      "Write(~/projects/**)",
      "Skill",
      "Skill(*)",
      "mcp__MCP_DOCKER__*",
      "mcp__apple-mail-imdinu__*",
      "mcp__apple-mail-patrickfreyer__*",
      "mcp__che-ical-mcp__*",
      "mcp__claude_ai_Google_Calendar__*",
      "mcp__google-workspace__*",
      "mcp__plugin_che-ical-mcp_ical__*",
      "mcp__plugin_context7_context7__*",
      "Bash(awk *)",
      "Bash(bash ~/claude/skills/**/*.sh)",
      "Bash(bash ~/claude/skills/**/*.sh *)",
      "Bash(cat *)",
      "Bash(cd *)",
      "Bash(convert *)",
      "Bash(cp *)",
      "Bash(curl *)",
      "Bash(deface *)",
      "Bash(du *)",
      "Bash(echo *)",
      "Bash(exiftool *)",
      "Bash(ffmpeg *)",
      "Bash(ffplay *)",
      "Bash(ffprobe *)",
      "Bash(file *)",
      "Bash(find)",
      "Bash(find *)",
      "Bash(git -C ~/.config/lnk add *)",
      "Bash(git -C ~/.config/lnk diff)",
      "Bash(git -C ~/.config/lnk diff *)",
      "Bash(git -C ~/.config/lnk log *)",
      "Bash(git -C ~/.config/lnk status)",
      "Bash(git -C ~/.config/lnk status *)",
      "Bash(git add *)",
      "Bash(git branch *)",
      "Bash(git check-ignore *)",
      "Bash(git commit *)",
      "Bash(git diff)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git pull)",
      "Bash(git pull *)",
      "Bash(git rev-parse *)",
      "Bash(git show *)",
      "Bash(git status)",
      "Bash(git status *)",
      "Bash(grep *)",
      "Bash(head)",
      "Bash(head *)",
      "Bash(jq *)",
      "Bash(lnk *)",
      "Bash(ls)",
      "Bash(ls *)",
      "Bash(magick *)",
      "Bash(mediainfo *)",
      "Bash(mkdir)",
      "Bash(mkdir *)",
      "Bash(mv *)",
      "Bash(open *)",
      "Bash(pbcopy)",
      "Bash(pbcopy *)",
      "Bash(pbpaste)",
      "Bash(pbpaste *)",
      "Bash(printf *)",
      "Bash(pyright *)",
      "Bash(quarto *)",
      "Bash(readlink *)",
      "Bash(realpath *)",
      "Bash(ruff *)",
      "Bash(ruff check *)",
      "Bash(ruff format *)",
      "Bash(sed *)",
      "Bash(stat *)",
      "Bash(tail)",
      "Bash(tail *)",
      "Bash(time *)",
      "Bash(touch *)",
      "Bash(uv *)",
      "Bash(uv run *)",
      "Bash(uv run ~/claude/skills/**/*.py)",
      "Bash(uv run ~/claude/skills/**/*.py *)",
      "Bash(wc *)",
      "Bash(which *)"
    ],
    "deny": []
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/eric/.claude/hooks/nag_docs.sh"
          },
          {
            "type": "command",
            "command": "/Users/eric/.claude/hooks/audit_python.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "if [[ \"$CLAUDE_FILE_PATH\" == *.py ]]; then ruff format \"$CLAUDE_FILE_PATH\" 2>/dev/null || true; fi"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "if [[ \"$CLAUDE_FILE_PATH\" == *.md || \"$CLAUDE_FILE_PATH\" == *.qmd ]]; then rumdl check --fix --config ~/.rumdl.toml \"$CLAUDE_FILE_PATH\" 2>/dev/null || true; fi"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "node /Users/eric/.claude/claude-limitline-fork/dist/index.js"
  },
  "enabledPlugins": {
    "pyright-lsp@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "hookify@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": false,
    "security-guidance@claude-plugins-official": true,
    "explanatory-output-style@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "github@claude-plugins-official": false,
    "feature-dev@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true,
    "che-ical-mcp@psychquant-claude-plugins": true
  },
  "extraKnownMarketplaces": {
    "psychquant-claude-plugins": {
      "source": {
        "source": "github",
        "repo": "PsychQuant/psychquant-claude-plugins"
      }
    }
  },
  "alwaysThinkingEnabled": true,
  "voiceEnabled": true
}
