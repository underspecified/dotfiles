{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Edit",
      "Edit(~/.claude/**)",
      "Edit(~/Downloads/**)",
      "Edit(~/git/**)",
      "Edit(~/Google_Drive/HRI-JP/projects/**)",
      "Edit(~/haru.md/**)",
      "Edit(~/projects/**)",
      "Read",
      "Read(*)",
      "Read(~/git/**)",
      "Read(~/haru.md/**)",
      "Read(~/projects/**)",
      "Search",
      "Skill",
      "Skill(*)",
      "TaskCreate",
      "TaskGet",
      "TaskList",
      "TaskOutput",
      "TaskStop",
      "TaskUpdate",
      "WebFetch",
      "WebSearch",
      "Write",
      "Write(~/.claude/**)",
      "Write(~/Downloads/**)",
      "Write(~/git/**)",
      "Write(~/Google_Drive/HRI-JP/projects/**)",
      "Write(~/haru.md/**)",
      "Write(~/projects/**)",
      "mcp__claude_ai_Gmail__*",
      "mcp__claude_ai_Google_Calendar__*",
      "mcp__google-workspace__*",
      "mcp__markitdown-mcp__*",
      "mcp__plugin_context7_context7__*",
      "Bash(awk *)",
      "Bash(bash *.sh)",
      "Bash(bash *.sh *)",
      "Bash(brew *)",
      "Bash(cat *)",
      "Bash(cd *)",
      "Bash(chmod *)",
      "Bash(claude *)",
      "Bash(convert *)",
      "Bash(cp *)",
      "Bash(curl *)",
      "Bash(deface *)",
      "Bash(diff *)",
      "Bash(du *)",
      "Bash(echo *)",
      "Bash(exiftool *)",
      "Bash(export *)",
      "Bash(ffmpeg *)",
      "Bash(ffplay *)",
      "Bash(ffprobe *)",
      "Bash(file *)",
      "Bash(find)",
      "Bash(find *)",
      "Bash(gh *)",
      "Bash(git -C *)",
      "Bash(grep *)",
      "Bash(head)",
      "Bash(head *)",
      "Bash(jq *)",
      "Bash(ksdiff *)",
      "Bash(lnk *)",
      "Bash(ls)",
      "Bash(ls *)",
      "Bash(magick *)",
      "Bash(mediainfo *)",
      "Bash(mkdir)",
      "Bash(mkdir *)",
      "Bash(mv *)",
      "Bash(open *)",
      "Bash(pandoc *)",
      "Bash(pbcopy)",
      "Bash(pbcopy *)",
      "Bash(pbpaste)",
      "Bash(pbpaste *)",
      "Bash(printf *)",
      "Bash(pyright *)",
      "Bash(quarto *)",
      "Bash(readlink *)",
      "Bash(realpath *)",
      "Bash(ruff *)",
      "Bash(ruff check *)",
      "Bash(ruff format *)",
      "Bash(sed *)",
      "Bash(sips *)",
      "Bash(soffice *)",
      "Bash(stat *)",
      "Bash(tail)",
      "Bash(tail *)",
      "Bash(time *)",
      "Bash(touch *)",
      "Bash(trash *)",
      "Bash(uv *)",
      "Bash(uv run *)",
      "Bash(wc *)",
      "Bash(which *)",
      "Bash(whisply *)"
    ],
    "deny": [
      "mcp__claude_ai_Mermaid_Chart__*"
    ],
    "defaultMode": "auto"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/audit_python.sh"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/git_gate.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "if [[ \"$CLAUDE_FILE_PATH\" == *.py ]]; then ruff format \"$CLAUDE_FILE_PATH\" 2>/dev/null || true; fi"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "if [[ \"$CLAUDE_FILE_PATH\" == *.md || \"$CLAUDE_FILE_PATH\" == *.qmd ]]; then rumdl check --fix --config ~/.rumdl.toml \"$CLAUDE_FILE_PATH\" 2>/dev/null || true; fi"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "node ~/.claude/statusline/claude-limitline/dist/index.js"
  },
  "enabledPlugins": {
    "pyright-lsp@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "hookify@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": false,
    "security-guidance@claude-plugins-official": true,
    "explanatory-output-style@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "github@claude-plugins-official": false,
    "feature-dev@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true,
    "che-ical-mcp@psychquant-claude-plugins": true
  },
  "extraKnownMarketplaces": {
    "psychquant-claude-plugins": {
      "source": {
        "source": "github",
        "repo": "PsychQuant/psychquant-claude-plugins"
      }
    }
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "showThinkingSummaries": true,
  "skipAutoPermissionPrompt": true
}
