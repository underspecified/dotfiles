#!/bin/bash

CUR_DIR=$(dirname $0)

get_os () {
    case $(uname) in
        "Darwin") echo "macos" ;;
        "Linux") echo "linux" ;;
        *) echo "unknown" ;;
    esac
}

os=$(get_os)
if [[ "$os" == "macos" ]]; then
    /Applications/1Password.app/Contents/MacOS/op-ssh-sign $@
elif [[ "$os" == "linux" ]]; then
    /opt/1Password/op-ssh-sign $@
fi
