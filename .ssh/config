### per-machine overlay — private host blocks live under ~/.ssh/config.d/
### (gitignored; sourced from 1Password on bootstrap)
Include ~/.ssh/config.d/*

### global settings

# ControlMaster auto
# ControlPath ~/.ssh/sock/%r@%h:%p
#ForwardAgent yes
ForwardX11 no
ForwardX11Trusted no
#PermitLocalCommand yes
TCPKeepAlive yes

### github

Host github.com
    User git
    Hostname ssh.github.com
    Port 443

Host *
    IdentityAgent ~/.1password/agent.sock
    AddKeysToAgent no
    StrictHostKeyChecking ask
    HashKnownHosts yes
