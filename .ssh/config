### global settings

# ControlMaster auto
# ControlPath ~/.ssh/sock/%r@%h:%p
#ForwardAgent yes
ForwardX11 no
ForwardX11Trusted no
#PermitLocalCommand yes
TCPKeepAlive yes

### github

Host github.com
    User git
    Port 22
    Hostname github.com
    #IdentitiesOnly yes
    #IdentityFile ~/.ssh/github_rsa

### HRI-JP

Host dgx01 REDACTED.example
    User REDACTED-USER
    HostName REDACTED.example

Host dgx02 REDACTED.example
    User REDACTED-USER
    HostName REDACTED.example

Host *
    IdentityAgent ~/.1password/agent.sock
    AddKeysToAgent no
    IdentitiesOnly yes
    StrictHostKeyChecking ask
    HashKnownHosts yes
