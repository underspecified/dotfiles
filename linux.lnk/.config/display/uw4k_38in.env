#!/usr/bin/env bash
# Single source of truth for display scaling.
#
# SCALE    — pixel geometry scaling only (cursor, borders, lock ring).
#            Change this to resize physical UI chrome without touching fonts.
#
# XFT_DPI  — font rendering DPI (written to Xft.dpi in .Xresources).
#            Controls how pt values map to pixels for all Xft/Pango apps.
#            Independent of SCALE — fonts stay constant when SCALE changes.
#
# QT_SCALE — Qt application scaling factor. Usually matches XFT_DPI / 96.
#
# FONT_*   — logical pt passed directly to each app. Unaffected by SCALE or
#            XFT_DPI — change these to resize specific UI text.

export SCALE=1.25
export XFT_DPI=111             # 96 × 2.0 — tune independently of SCALE
export QT_SCALE=1.25            # XFT_DPI / 96

# Font sizes (pt) — literal values passed to apps
export FONT_UI=15              # i3 titles, status bar
export FONT_DUNST=15           # dunst notifications
export FONT_LOCK=64            # lock screen clock
export FONT_DMENU=18           # dmenu/j4 launcher
export FONT_TERM=10            # kitty terminal
export FONT_ZED_EDITOR=15      # zed editor buffer
export FONT_ZED_UI=15          # zed editor UI chrome

# Pixel geometry at 1× — multiplied by SCALE at runtime
export BASE_CURSOR=16          # cursor
export BASE_BORDER=4           # WM border + gap
export BASE_RING_WIDTH=64      # i3lock ring
export BASE_I3LOCK_RADIUS=270  # i3lock radius
export BASE_DATE_OFFSET=64     # i3lock date offset

# swaylock geometry — unused until sway scaling is wired up
export BASE_RING_RADIUS=64
export BASE_RING_THICK=16
