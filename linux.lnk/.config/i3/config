# Please see http://i3wm.org/docs/userguide.html for a complete reference!

### update config
exec_always --no-startup-id $HOME/.local/bin/i3_update_config

### config files

# load i3-specific settings
include conf/system.conf

# load app settings
include ../wm/conf/apps.conf

# load keybinding settings
include ../wm/conf/keys.conf

# load gnome settings
include ../wm/conf/gnome.conf

# load mode settings
include ../wm/conf/modes.conf

# load theme and theme-dependent settings
include ../wm/conf/theme.conf

### load i3-specific configs
include conf/i3bar.conf
