#!/bin/bash

set -euo pipefail
shopt -s nullglob

export mode="${1:-$(darkman get)}"
source "$HOME/.local/share/colors/selenized_${mode}.env"
export WALLPAPER_CMD="output * bg $wallpaper fill"

for conf in "$HOME/.config/wm"/conf/*.conf.in \
            "$HOME/.config/sway"/conf/*.conf.in \
            "$HOME/.config/swaylock/config.in"; do
    [[ -f "$conf" ]] || continue
    envsubst < "$conf" > "${conf%.in}"
done
