#!/bin/bash

set -euo pipefail

LOCK_MIN=5
LOCK_SEC=$(($LOCK_MIN * 60))
IDLE_MIN=10
IDLE_SEC=$(($IDLE_MIN * 60))

mode=$(darkman get)
source "$HOME/.local/share/colors/selenized_${mode}.env"
source "$HOME/.config/display.env"

_scale() { awk "BEGIN{printf \"%d\", int($1 * ${SCALE} + 0.5)}"; }
font_pt="${font}"
font_sz="${FONT_LOCK}"
ring_width_px=$(_scale "${BASE_RING_WIDTH}")
i3lock_radius_px=$(_scale "${BASE_I3LOCK_RADIUS}")
date_offset=$(_scale "${BASE_DATE_OFFSET}")

# Ensure dunst always unpauses, even if i3lock crashes or the script is killed
trap 'dunstctl set-paused false 2>/dev/null || true' EXIT INT TERM HUP

# Pause notifications to avoid X grab race on unlock
if command -v dunstctl &>/dev/null; then
    dunstctl set-paused true
fi

sleep 0.5

LC_ALL="en_US.UTF-8" i3lock \
  --insidever-color=$bg_0 \
  --insidewrong-color=$bg_0 \
  --inside-color=$bg_0 \
  --ringver-color=$green \
  --ringwrong-color=$red \
  --ring-color=$blue \
  --line-uses-ring \
  --keyhl-color=$magenta \
  --bshl-color=$orange \
  --separator-color=$bg_1 \
  --verif-color=$green \
  --wrong-color=$red \
  --layout-color=$blue \
  --date-color=$blue \
  --time-color=$blue \
  --screen 1 \
  --blur 1 \
  --clock \
  --indicator \
  --time-str="%H:%M:%S" \
  --date-str="%a %b %e %Y" \
  --date-pos="tx:ty+${date_offset}" \
  --verif-text="Verifying..." \
  --wrong-text="Auth Failed" \
  --noinput="No Input" \
  --lock-text="Locking..." \
  --lockfailed="Lock Failed" \
  --ignore-empty-password \
  --time-font="$font_pt" \
  --date-font="$font_pt" \
  --layout-font="$font_pt" \
  --verif-font="$font_pt" \
  --wrong-font="$font_pt" \
  --time-size=$font_sz \
  --date-size=$font_sz \
  --layout-size=$font_sz \
  --verif-size=$font_sz \
  --wrong-size=$font_sz \
  --radius=$i3lock_radius_px \
  --ring-width=$ring_width_px \
  --pass-media-keys \
  --pass-screen-keys \
  --pass-volume-keys \
  --image="$wallpaper" \
  --fill \
  --nofork
