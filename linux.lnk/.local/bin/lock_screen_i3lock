#!/bin/bash

LOCK_MIN=5
LOCK_SEC=$(($LOCK_MIN * 60))
IDLE_MIN=10
IDLE_SEC=$(($IDLE_MIN * 60))

mode=$(darkman get)
font_pt="$font 36"

source "$HOME/.local/share/colors/selenized_${mode}.env"

# Pause notifications to avoid X grab race on unlock
command -v dunstctl &>/dev/null && dunstctl set-paused true

sleep 0.5

LC_ALL="en_US.UTF-8" i3lock \
  --insidever-color=$bg_0 \
  --insidewrong-color=$bg_0 \
  --inside-color=$bg_0 \
  --ringver-color=$green \
  --ringwrong-color=$red \
  --ring-color=$blue \
  --line-uses-ring \
  --keyhl-color=$magenta \
  --bshl-color=$orange \
  --separator-color=$bg_1 \
  --verif-color=$green \
  --wrong-color=$red \
  --layout-color=$blue \
  --date-color=$blue \
  --time-color=$blue \
  --screen 1 \
  --blur 1 \
  --clock \
  --indicator \
  --time-str="%H:%M:%S" \
  --date-str="%a %b %e %Y" \
  --verif-text="Verifying..." \
  --wrong-text="Auth Failed" \
  --noinput="No Input" \
  --lock-text="Locking..." \
  --lockfailed="Lock Failed" \
  --ignore-empty-password \
  --time-font="$font_pt" \
  --date-font="$font_pt" \
  --layout-font="$font_pt" \
  --verif-font="$font_pt" \
  --wrong-font="$font_pt" \
  --radius=100 \
  --ring-width=20 \
  --pass-media-keys \
  --pass-screen-keys \
  --pass-volume-keys \
  --image="$wallpaper" \
  --fill \
  --nofork

# Resume notifications after unlock
command -v dunstctl &>/dev/null && dunstctl set-paused false
