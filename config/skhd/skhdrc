### Launch apps
# application launcher: Alfred
ctrl + alt - space : open_alfred
# change themes
ctrl + alt - d : change_theme.sh
# change themes
shift + ctrl + alt - d : open_drafts
# terminal: kitty
ctrl + alt - return : open_kitty
# broswer: Safari
shift + ctrl + alt - return : open_safari
# finder
shift + ctrl + alt - f : open_finder

### Configuration
ctrl + alt - c : skhd --reload
ctrl + alt - r : yabai --restart-service; skhd --restart-service


# load column layout and rebalance apps
ctrl + alt - a : yabai_config_layout_cols


# Focus : Focus left window
ctrl + alt - h : yabai3 focus west
# Focus : Focus bottom window
ctrl + alt - j : yabai3 focus south
# Focus : Focus top window
ctrl + alt - k : yabai3 focus north
# Focus : Focus right window
ctrl + alt - l : yabai3 focus east
# Focus : Focus left window
ctrl + alt - left : yabai3 focus west
# Focus : Focus bottom window
ctrl + alt - down : yabai3 focus south
# Focus : Focus top window
ctrl + alt - up : yabai3 focus north
# Focus : Focus right window
ctrl + alt - right : yabai3 focus east

# Swap : Swap left window
shift + ctrl + alt - h : yabai3 move west
# Swap : Swap bottom window
shift + ctrl + alt - j : yabai3 move north
# Swap : Swap top window
shift + ctrl + alt - k : yabai3 move south
# Swap : Swap right window
shift + ctrl + alt - l : yabai3 move east
# Swap : Swap left window
shift + ctrl + alt - left : yabai3 move west
# Swap : Swap bottom window
shift + ctrl + alt - down : yabai3 move north
# Swap : Swap top window
shift + ctrl + alt - up : yabai3 move south
# Swap : Swap right window
shift + ctrl + alt - right : yabai3 move east

# Warp : Warp window to left
ctrl + alt + cmd - h : yabai3 stack-enter west
# Warp : Warp window to bottom
ctrl + alt + cmd - j : yabai3 stack-enter south
# Warp : Warp window to top
ctrl + alt + cmd - k : yabai3 stack-enter north
# Warp : Warp window to left
ctrl + alt + cmd - l : yabai3 stack-enter east
# Warp : Warp window to left
ctrl + alt + cmd - left : yabai3 stack-enter west
# Warp : Warp window to bottom
ctrl + alt + cmd - down : yabai3 stack-enter south
# Warp : Warp window to top
ctrl + alt + cmd - up : yabai3 stack-enter north
# Warp : Warp window to left
ctrl + alt + cmd - right : yabai3 stack-enter east

# Grow window: ctrl + alt - equals
ctrl + alt - 0x18 : yabai_window_grow
# Shrink windows: ctrl - alt - minus
ctrl + alt - 0x1B : yabai_window_shrink

# Resize: Toggle window fullscreen zoom
ctrl + alt - f : yabai -m window --toggle zoom-fullscreen

# Misc: Float + resize / unfloat window
shift + ctrl + alt - space : yabai -m window --toggle float && \
    yabai -m window --grid 4:4:1:1:2:2

# Misc: Float / unfloat window: ctrl + alt - .
ctrl + alt - 0x2F : yabai -m window --toggle float

# Spaces navigation: move between spaces
ctrl + alt - 1 : yabai -m space --focus 1
ctrl + alt - 2 : yabai -m space --focus 2
ctrl + alt - 3 : yabai -m space --focus 3
ctrl + alt - 4 : yabai -m space --focus 4
ctrl + alt - 5 : yabai -m space --focus 5
ctrl + alt - 6 : yabai -m space --focus 6
ctrl + alt - 7 : yabai -m space --focus 7
ctrl + alt - 8 : yabai -m space --focus 8
ctrl + alt - 9 : yabai -m space --focus 9

# Spaces navigation: move apps between spaces
shift + ctrl + alt - 1 : yabai -m window --space 1
shift + ctrl + alt - 2 : yabai -m window --space 2
shift + ctrl + alt - 3 : yabai -m window --space 3
shift + ctrl + alt - 4 : yabai -m window --space 4
shift + ctrl + alt - 5 : yabai -m window --space 5
shift + ctrl + alt - 6 : yabai -m window --space 6
shift + ctrl + alt - 7 : yabai -m window --space 7
shift + ctrl + alt - 8 : yabai -m window --space 8
shift + ctrl + alt - 9 : yabai -m window --space 9
