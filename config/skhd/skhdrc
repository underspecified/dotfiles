### Launch apps
# application launcher: Alfred
ctrl + alt - space : osascript -e 'tell application id "com.runningwithcrayons.Alfred" to search'
# change themes
ctrl + alt - d : change_theme.sh
# change themes
shift + ctrl + alt - d : open -a Drafts
# terminal: kitty
ctrl + alt - return : open_kitty
# broswer: Safari
shift + ctrl + alt - return : open_safari
# finder
shift + ctrl + alt - f : open ~

### Configuration
ctrl + alt - c : skhd --reload
ctrl + alt - r : yabai --restart-service; skhd --restart-service


