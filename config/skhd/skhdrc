# Launch : Help
cmd + alt + ctrl - space : yabai -m rule --add app="^yabai-help-overlay$" sticky=on layer=above manage=off && open /Applications/yabai-help-overlay.app

# Layout : 3 column
cmd + alt + ctrl - 3 : $HOME/.config/yabai/scripts/yabai_config_layout_3col
# Layout : BSP
cmd + alt + ctrl - b : $HOME/.config/yabai/scripts/yabai_config_layout_bsp
# Layout : Stack
cmd + alt + ctrl - s : $HOME/.config/yabai/scripts/yabai_config_layout_stack

# Focus : Focus recent window
cmd + alt + ctrl - 0x2C : $HOME/.config/yabai/scripts/yabai_window_focus_recent
# Focus : Focus left window
cmd + alt + ctrl - left : $HOME/.config/yabai/scripts/yabai_window_focus_left
# Focus : Focus bottom window
cmd + alt + ctrl - down : $HOME/.config/yabai/scripts/yabai_window_focus_down
# Focus : Focus top window
cmd + alt + ctrl - up : $HOME/.config/yabai/scripts/yabai_window_focus_up
# Focus : Focus right window
cmd + alt + ctrl - right : $HOME/.config/yabai/scripts/yabai_window_focus_right

# Swap : Swap recent window
shift + cmd + alt + ctrl - 0x2C : $HOME/.config/yabai/scripts/yabai_window_swap_recent
# Swap : Swap left window
shift + cmd + alt + ctrl - left : $HOME/.config/yabai/scripts/yabai_window_swap_left
# Swap : Swap bottom window
shift + cmd + alt + ctrl - down : $HOME/.config/yabai/scripts/yabai_window_swap_down
# Swap : Swap top window
shift + cmd + alt + ctrl - up : $HOME/.config/yabai/scripts/yabai_window_swap_up
# Swap : Swap right window
shift + cmd + alt + ctrl - right : $HOME/.config/yabai/scripts/yabai_window_swap_right

# Warp : Warp window to left
shift + cmd - left : yabai -m window --warp west
# Warp : Warp window to bottom
shift + cmd - down : yabai -m window --warp south
# Warp : Warp window to top
shift + cmd - up : yabai -m window --warp north
# Warp : Warp window to left
shift + cmd - right : yabai -m window --warp east

# Move : Move window left
shift + ctrl - a : yabai -m window --move rel:-20:0
# Move : Move window top
shift + ctrl - s : yabai -m window --move rel:0:20
# Move : Move window bottom
shift + ctrl - w : yabai -m window --move rel:0:-20
# Move : Move window right
shift + ctrl - d : yabai -m window --move rel:20:0

# Resize : Stretch window left
shift + cmd + alt + ctrl - a : yabai -m window --resize left :-20:0
# Resize : Stretch window top
shift + cmd + alt + ctrl - s : yabai -m window --resize bottom:0:20
# Resize : Stretch window bottom
shift + cmd + alt + ctrl - w : yabai -m window --resize top:0:-20
# Resize : Stretch window right
shift + cmd + alt + ctrl - d : yabai -m window --resize right:20:0

# Resize : Shrink window left
shift + cmd - a : yabai -m window --resize left :20:0
# Resize : Shrink window bottom
shift + cmd - s : yabai -m window --resize bottom:0:-20
# Resize : Shrink window top
shift + cmd - w : yabai -m window --resize top:0:20
# Resize : Shrink window right
shift + cmd - d : yabai -m window --resize right:-20:0

# Misc: Rotate tree
cmd + alt + ctrl - r : yabai -m space --rotate 90

# Misc: Mirror tree y-axis
cmd + alt + ctrl - y : yabai -m space --mirror y-axis

# Misc: Mirror tree x-axis
cmd + alt + ctrl - x : yabai -m space --mirror x-axis

# Misc: Toggle desktop offset
cmd + alt + ctrl - a : yabai -m space --toggle padding && yabai -m space --toggle gap

# Resize: Toggle window fullscreen zoom
cmd + alt + ctrl - f : yabai -m window --toggle zoom-fullscreen

# Resize: Toggle window native fullscreen
shift + cmd + alt + ctrl - f : yabai -m window --toggle native-fullscreen

# Misc: Toggle window split type
cmd + alt + ctrl - e : yabai -m window --toggle split

# Misc: Float / unfloat window
cmd + alt + ctrl - t : yabai -m window --toggle float && yabai -m window --grid 4:4:1:1:2:2
