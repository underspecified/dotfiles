# Default config for sway
#
# Copy this to ~/.config/sway/config and edit it to your liking.
#
# Read `man 5 sway` for a complete reference.

include /etc/sway/config-vars.d/*
include /etc/sway/config.d/*

### config files

# load wm-specific settings
include conf/system.conf

# load app settings
include ../wm/conf/apps.conf

# load keybinding settings
include ../wm/conf/keys.conf

# load gnome settings
include ../wm/conf/gnome.conf

# load mode settings
include ../wm/conf/modes.conf

# load theme and theme-dependent settings
include ../wm/conf/theme.conf
include conf/swaybar.conf
