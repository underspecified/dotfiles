# Default config for sway
#
# Copy this to ~/.config/sway/config and edit it to your liking.
#
# Read `man 5 sway` for a complete reference.

exec systemctl --user import-environment WAYLAND_DISPLAY XDG_CURRENT_DESKTOP WLR_NO_HARDWARE_CURSORS WLR_RENDERER ELECTRON_OZONE_PLATFORM_HINT PATH
exec dbus-update-activation-environment --systemd WAYLAND_DISPLAY XDG_CURRENT_DESKTOP WLR_NO_HARDWARE_CURSORS WLR_RENDERER ELECTRON_OZONE_PLATFORM_HINT PATH

include /etc/sway/config-vars.d/*
include /etc/sway/config.d/*

### config files

# load wm-specific settings
include conf/system.conf

# load app settings
include conf/apps.conf

# load keybinding settings
include conf/keys.conf

# load gnome settings
include conf/gnome.conf

# load mode settings
include conf/modes.conf

# load theme and theme-dependent settings
include conf/theme.conf
include conf/swaybar.conf
