#!/bin/bash

echo_and_eval () {
    echo "$@"
    eval "$@"
}

CURDIR=$(dirname $0)
DOTFILES=$(realpath $CURDIR/../../..)
SWAY_DIR="$DOTFILES/config/sway"
WM_DIR="$DOTFILES/config/wm"

export mode=${1:-$(darkman get)}
source "$DOTFILES/colors/selenized_${mode}.env"
export WALLPAPER_CMD="output * bg $wallpaper fill"

for conf in "$WM_DIR"/conf/*.conf.in \
            "$SWAY_DIR"/conf/*.conf.in \
            "$DOTFILES"/config/swaylock/config.in; do
    envsubst < "$conf" | tee "${conf%.in}"
done
