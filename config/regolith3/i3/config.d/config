## toggle the light/dark theme
bindsym $mod+Shift+d exec ~/git/dotfiles/linux/bin/change_theme.sh toggle

### programs to launch at startup
## load custom keymaps
#exec_always --no-startup-id xmodmap ~/.Xmodmap
exec_always --no-startup-id setxkbmap -option "caps:hyper"

## reset theme
#exec_always --no-startup-id ~/git/dotfiles/linux/bin/change_theme.sh auto
