#!/bin/bash

echo_and_eval () {
    echo "$@"
    eval "$@"
}

CURDIR=$(dirname $0)
DOTFILES=$(realpath $CURDIR/../../..)
I3_DIR="$DOTFILES/config/i3"

export mode=$(darkman get)
source "$DOTFILES/colors/selenized_${mode}.env"

envsubst < "$I3_DIR/conf/theme.conf.in" |
tee "$I3_DIR/conf/theme.conf"

envsubst < "$I3_DIR/conf/i3bar.conf.in" |
tee "$I3_DIR/conf/i3bar.conf"

envsubst < "$DOTFILES/config/i3status/config.in" |
tee "$DOTFILES/config/i3status/config"
