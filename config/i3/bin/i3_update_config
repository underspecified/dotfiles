#!/bin/bash

echo_and_eval () {
    echo "$@"
    eval "$@"
}

CURDIR=$(dirname $0)
DOTFILES=$(realpath $CURDIR/../../..)
I3_DIR="$DOTFILES/config/i3"
WM_DIR="$DOTFILES/config/wm"

export mode=$(darkman get)
source "$DOTFILES/colors/selenized_${mode}.env"
export WALLPAPER_CMD="exec_always --no-startup-id feh --bg-fill $wallpaper"

for conf in "$WM_DIR"/conf/*.conf.in \
            "$I3_DIR"/conf/*.conf.in \
            "$DOTFILES"/config/i3status/config.in; do
    envsubst < "$conf" | tee "${conf%.in}"
done
