LOCK_MIN=1
LOCK_SEC=60
IDLE_MIN=2
IDLE_SEC=120

mode=$(darkman get)
source "$I3_DIR/themes/selenized_${mode}.env"

gsettings set org.gnome.desktop.background picture-uri "file://$wallpaper"
