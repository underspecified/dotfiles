#!/bin/bash

LOCK_MIN=1
LOCK_SEC=60
IDLE_MIN=2
IDLE_SEC=120

[[ -f "$1" ]] && source "$1"
font_pt="$font 20"

LC_ALL="en_US.UTF-8" i3lock \
  --insidever-color=$bg_0 \
  --insidewrong-color=$bg_0 \
  --inside-color=$bg_0 \
  --ringver-color=$green \
  --ringwrong-color=$red \
  --ringver-color=$green \
  --ringwrong-color=$red \
  --ring-color=$blue \
  --line-uses-ring \
  --keyhl-color=$magenta \
  --bshl-color=$orange \
  --separator-color=$bg_1 \
  --verif-color=$green \
  --wrong-color=$red \
  --layout-color=$blue \
  --date-color=$blue \
  --time-color=$blue \
  --screen 1 \
  --blur 1 \
  --clock \
  --indicator \
  --time-str="%H:%M:%S" \
  --date-str="%a %b %e %Y" \
  --verif-text="Verifying..." \
  --wrong-text="Auth Failed" \
  --noinput="No Input" \
  --lock-text="Locking..." \
  --lockfailed="Lock Failed" \
  --ignore-empty-password \
  --time-font="$font_pt" \
  --date-font="$font_pt" \
  --layout-font="$font_pt" \
  --verif-font="$font_pt" \
  --wrong-font="$font_pt" \
  --radius=100 \
  --ring-width=20 \
  --pass-media-keys \
  --pass-screen-keys \
  --pass-volume-keys \
  --image="$wallpaper"
