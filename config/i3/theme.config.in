# load theme
set $mode $mode
set $themes $HOME/.config/i3/themes

include $themes/i3-selenized-$mode.conf

# start dmenu (a program launcher)
bindsym $mod+space exec --no-startup-id $themes/dmenu_selenized_$mode

# lock screen
bindsym $mod+l exec i3lock -i $themes/selenized-$mode-wallpaper.png -u

# wallpaper
exec_always --no-startup-id feh --bg-fill $themes/selenized-$mode-wallpaper.png
