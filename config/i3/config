# Please see http://i3wm.org/docs/userguide.html for a complete reference!

# darkman
exec --no-startup-id systemctl --user import-environment XDG_DATA_DIRS I3SOCK PATH DISPLAY WAYLAND_DISPLAY QT_AUTO_SCREEN_SCALE_FACTOR QT_SCALE_FACTOR GDK_SCALE GDK_DPI_SCALE
exec --no-startup-id systemctl --user restart darkman

# X settings
#exec --no-startup-id xrdb -merge ~/.Xresources
exec --no-startup-id xsettingsd

### config files

# load keybinding settings
include conf/keys.conf

# load app settings
include conf/apps.conf

# load mode settings
include conf/modes.conf

# load gnome settings
include conf/gnome.conf

# load theme and theme-dependent settings
include conf/theme.conf
