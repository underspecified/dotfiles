### i3 theme settings

### modifier keys
set $mod Mod4

#set ${mode} {dark,light}
set $theme_env $HOME/git/dotfiles/config/i3/themes/selenized_$mode.env
set $wallpaper $HOME/git/dotfiles/wallpaper/selenized_$mode_hd.png

# cursor theme
exec --no-startup-id xrdb -merge $HOME/git/dotfiles/config/i3/themes/$mode.Xresources

# Font for window titles.
set $font "Meslo LG S Regular Nerd Font Complete"
font pango:$font 8

# clientclass border backgr. text indicator
client.focused $blue $blue $bg_1 $green
client.focused_inactive $cyan $cyan $bg_1 $violet
client.unfocused $bg_1 $bg_1 $fg_0 $dim_0
client.urgent $red $red $bg_1 $orange

# borders
default_border normal 4
default_floating_border normal 4
gaps inner 4
gaps outer 0

# start program launcher
#set $launcher $HOME/git/dotfiles/config/i3/bin/launch_rofi
set $launcher $HOME/git/dotfiles/config/i3/bin/launch_dmenu
bindsym $mod+space exec --no-startup-id $launcher $theme_env

# wallpaper
exec_always --no-startup-id feh --bg-fill $wallpaper

### lock screen
set $screensaver $HOME/git/dotfiles/config/i3/bin/start_screensaver_xautolock
set $locker $HOME/git/dotfiles/config/i3/bin/lock_screen_i3lock
#set $screensaver $HOME/git/dotfiles/config/i3/bin/start_screensaver_xdg
#set $locker $HOME/git/dotfiles/config/i3/bin/lock_screen_xdg

exec_always --no-startup-id $screensaver $wallpaper
bindsym $mod+l exec $locker $wallpaper
