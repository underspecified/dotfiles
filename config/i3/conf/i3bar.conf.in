### i3 bar config: needs color definiton from themes/selenized-*.conf
# Font for window titles. Will also be used by the bar unless a different font
# is used in the bar {} block below.
font pango:$font 12

# Start i3bar to display a workspace bar (plus the system information i3status
# finds out, if available)
bar {
        font pango:$font 10
        #mode hide
        status_command i3status --config $HOME/git/dotfiles/config/i3status/selenized_$mode.conf

        colors {
            separator $blue
            background $bg_0
            statusline $fg_2
            focused_workspace $blue $blue $bg_0
            active_workspace $cyan $blue $bg_1
            inactive_workspace $bg_1 $bg_1 $fg_0
            urgent_workspace $red $red $bg_1
        }
}

# clientclass border backgr. text indicator
client.focused $blue $blue $bg_1 $green
client.focused_inactive $cyan $cyan $bg_1 $violet
client.unfocused $bg_1 $bg_1 $fg_0 $dim_0
client.urgent $red $red $bg_1 $orange
