# X11 hidpi — derived from ~/.local/share/display/display/env
# GTK scaling is driven by Xft.dpi in .Xresources (generated by i3_update_config)
# GDK_SCALE only supports integers so we don't set it
source "$HOME/.config/display/env"
export QT_AUTO_SCREEN_SCALE_FACTOR=0
export QT_SCALE_FACTOR=$QT_SCALE
export XCURSOR_SIZE=$(awk "BEGIN{printf \"%d\", int(${BASE_CURSOR} * ${SCALE} + 0.5)}")
export CHROMIUM_FLAGS="--force-device-scale-factor=${SCALE}"
