#!/bin/env zsh

# yabai scripts
export PATH="$HOME/.config/yabai/scripts:$PATH"

# Homebrew
export PATH=/opt/homebrew/bin:$PATH
export PATH=/opt/homebrew/sbin:$PATH
export MANPATH=/opt/homebrew/share/man:$MANPATH

# For homebrew github auth (fetched from 1Password)
export HOMEBREW_GITHUB_API_TOKEN="$(op read 'op://Personal/Homebrew GitHub Token/credential' 2>/dev/null)"

# Homebrew Cocoa Emacs
emacs_cli="/opt/homebrew/bin/emacs -nw"
emacs_cocoa="/Applications/Emacs.app/Contents/MacOS/Emacs"
alias emacs="$emacs_cli"

# fix POSIX mode zcat appending .Z to all file names
alias zcat="gzcat"

# Quick way to rebuild the Launch Services database and get rid
# of duplicates in the Open With submenu.
alias fixopenwith='/System/Library/Frameworks/CoreServices.framework/Frameworks/LaunchServices.framework/Support/lsregister -kill -r -domain local -domain system -domain user'

# MacTex
#export TEXDIR=/usr/local/texlive/2025
export TEXDIR=/Library/TeX
export PATH=$PATH:$TEXDIR/texbin
export MANPATH=$MANPATH:$TEXDIR/Distributions/.DefaultTeX/Contents/Man
#export TEXMFHOME=$HOME/Library/texmf

# Plan 9 default browser
export BROWSER="/Applications/Safari.app"

safari () {
    open -a /Applications/Safari.app "$@"
}

# YourKit Java profiler
ykprof() {
    JAVA_TOOL_OPTIONS="$JAVA_TOOL_OPTIONS -agentpath:/Applications/YourKit.app/Contents/Resources/bin/mac/libyjpagent.jnilib" $@
}

# bun completions (added to fpath; compinit in .zshrc handles loading)
[[ -d "$HOME/.bun" ]] && fpath=("$HOME/.bun" $fpath)

# LM Studio CLI
export PATH="$PATH:$HOME/.cache/lm-studio/bin"


alias claude_cage='container run -it \
  --volume ${PWD}:/app \
  --volume ${HOME}/.claude:/app/.claude \
  --volume ${HOME}/.claude.json:/app/.claude.json \
  ghcr.io/gendosu/claude-code-docker:latest claude
'
