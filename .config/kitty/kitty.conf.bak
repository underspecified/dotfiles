# Fonts
# font_family      family='iAWriterMonoV-Text'
# bold_font        family='iAWriterMonoV-SemiBold'
# italic_font      family='iAWriterMonoV-TextItalic'
# bold_italic_font family='iAWriterMonoV-SemiBoldItalic'
font_size 8.0

# Layout
enabled_layouts grid, *

# Window borders
window_border_width 2.5pt

# Behavior
confirm_os_window_close 0
shell zsh
editor zed
allow_remote_control yes
linux_display_server auto


# BEGIN_KITTY_FONTS
font_family      family="MesloLGMDZ Nerd Font"
bold_font        auto
italic_font      auto
bold_italic_font auto
# END_KITTY_FONTS