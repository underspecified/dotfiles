#!/usr/bin/env bash

toggle_zed () {
    echo_and_eval sed -i.bak -r 's/"mode": ".+"/"mode": "'$1'"/' \
        "$CONFIG_DIR/zed/settings.json"
}

if [[ $1 == "dark" ]]; then
    mode="dark"
elif [[ $1 == "light" ]]; then
    mode="light"
else
    [[ $(get_macos_mode) == "light" ]] && mode="dark" || mode="light"
fi

echo "toggle_zed => $mode"
toggle_zed $mode
