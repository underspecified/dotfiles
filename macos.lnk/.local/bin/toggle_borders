#!/usr/bin/env bash

toggle_borders () {
    ~/.config/borders/bordersrc_$1
}

if [[ $1 == "dark" ]]; then
    mode="dark"
elif [[ $1 == "light" ]]; then
    mode="light"
else
    [[ $(get_macos_mode) == "light" ]] && mode="dark" || mode="light"
fi

echo "toggle_borders => $mode"
toggle_borders $mode
