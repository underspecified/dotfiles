### set paths
PATH="/opt/homebrew/bin:$PATH"
SCRIPTS_DIR=$(dirname "${BASH_SOURCE:-$0}")

CURR_SPACE=$(yabai -m query --spaces | jq -e '.[] | select(."has-focus" == true).index')
NUM_SPACES=$(yabai -m query --spaces | jq length)
NEXT_SPACE=$(((CURR_SPACE + 1) % NUM_SPACES))

yabai -m space --focus $NEXT_SPACE && \
sleep 0.01 && \
yabai -m space --focus $CURR_SPACE
