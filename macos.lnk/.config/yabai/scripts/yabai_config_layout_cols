#!/bin/bash
# Configure column layout based on display width.
# Columns = floor(display_width / MIN_COL_WIDTH), minimum 1.

PATH="/opt/homebrew/bin:$PATH"
SCRIPTS_DIR=$(cd "$(dirname "${BASH_SOURCE:-$0}")" && pwd)

# Minimum column width in pixels (override via env or $1)
MIN_COL_WIDTH=${1:-${MIN_COL_WIDTH:-750}}

# Display width (integer pixels)
display_w=$(yabai -m query --displays --display | jq '.frame.w | floor')

# Column count: as many as fit without going below MIN_COL_WIDTH
max_cols=$(( display_w / MIN_COL_WIDTH ))
(( max_cols < 1 )) && max_cols=1

col_width=$(( display_w / max_cols ))
split_ratio=$(jq -n "$col_width / $display_w")

# Apply layout
yabai -m config layout bsp
yabai -m config split_ratio "$split_ratio"

# Register signal handlers (replace any existing)
for event in window_focused application_activated; do
    label="${event}_yabai_window_insert_col"
    yabai -m signal --remove "$label" 2>/dev/null
    yabai -m signal --add \
        label="$label" \
        active=yes \
        event="$event" \
        action="$SCRIPTS_DIR/yabai_window_insert_col $max_cols $col_width"
done

# Rebalance on every new window so columns stay even
label="window_created_rebalance"
yabai -m signal --remove "$label" 2>/dev/null
yabai -m signal --add \
    label="$label" \
    event="window_created" \
    action="yabai -m space --balance"

# Rebalance all spaces
yabai -m query --spaces | jq -r '.[].index' |
    xargs -I{} yabai -m space {} --balance

echo "columns: ${max_cols}, col_width: ${col_width}px, split_ratio: ${split_ratio}, display: ${display_w}px"
