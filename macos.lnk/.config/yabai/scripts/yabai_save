#!/bin/bash
# Save current yabai window positions to a snapshot file.
# Usage: yabai_save [--archive]
#   --archive  Also save a timestamped copy to snapshots/ dir

PATH="/opt/homebrew/bin:$PATH"
set -euo pipefail

STATE_DIR="$HOME/.local/state/yabai"
SNAPSHOT="$STATE_DIR/snapshot.json"
mkdir -p "$STATE_DIR"

# Query current state
windows=$(yabai -m query --windows | jq '[.[] | select(.["is-hidden"] == false and .["is-minimized"] == false)]')
spaces=$(yabai -m query --spaces)
displays=$(yabai -m query --displays)
timestamp=$(date -u +"%Y-%m-%dT%H:%M:%SZ")

# Build snapshot JSON
jq -n \
    --arg ts "$timestamp" \
    --argjson windows "$windows" \
    --argjson spaces "$spaces" \
    --argjson displays "$displays" \
    '{
        timestamp: $ts,
        displays: [$displays[] | {index, uuid, frame}],
        spaces: [$spaces[] | {index, label, display}],
        windows: [$windows[] | {
            app,
            title,
            space,
            "is-floating": .["is-floating"],
            frame
        }]
    }' > "$SNAPSHOT"

window_count=$(jq '.windows | length' "$SNAPSHOT")
echo "saved $window_count windows to $SNAPSHOT" >&2

# Archive if requested
if [[ "${1:-}" == "--archive" ]]; then
    archive_dir="$STATE_DIR/snapshots"
    mkdir -p "$archive_dir"
    archive_file="$archive_dir/$(date +%Y%m%d_%H%M%S).json"
    cp "$SNAPSHOT" "$archive_file"
    echo "archived to $archive_file" >&2
fi
