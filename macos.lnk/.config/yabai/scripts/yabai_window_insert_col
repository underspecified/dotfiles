#!/bin/bash
# Signal handler: set insert direction for column layout.
# Fired on window_focused / application_activated.
# Args: $1 = target column width (baked into signal action)
col_width=${1:-800}
threshold=$(( col_width + col_width / 10 ))

# Single query: narrowest tiled window in current space
min_w=$(yabai -m query --windows --space |
    jq '[.[] | select(."is-floating" == false) | .frame.w] | min // 9999')

# If narrowest window can still be split, insert horizontally (new column);
# otherwise insert vertically (stack in existing column).
if (( ${min_w%.*} >= threshold )); then
    yabai -m window --insert east
else
    yabai -m window --insert south
fi
