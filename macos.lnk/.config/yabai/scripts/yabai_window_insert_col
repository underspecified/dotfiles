#!/bin/bash
# Signal handler: set insert direction for column layout.
# Fired on window_focused / application_activated.
# Args: $1 = max columns, $2 = expected column width (for spatial binning)
max_cols=${1:-3}
col_width=${2:-800}

# Count columns by binning tiled window x-positions into column-width slots.
# BSP balancing doesn't produce pixel-perfect alignment, so exact x comparison
# fails — dividing by col_width and flooring groups nearby windows correctly.
num_cols=$(yabai -m query --windows --space |
    jq --arg cw "$col_width" \
    '[.[] | select(."is-floating" == false) | .frame.x / ($cw | tonumber) | floor] | unique | length')

if (( num_cols < max_cols )); then
    yabai -m window --insert east
else
    yabai -m window --insert south
fi
