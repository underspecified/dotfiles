#!/usr/bin/env sh

#sleep 3

### set paths
PATH="/opt/homebrew/bin:$PATH"
YABAI_DIR=$(dirname "${BASH_SOURCE:-$0}")

### start script add-on
yabai -m signal --add label="dock_did_restart__load_sa" event=dock_did_restart action="sudo yabai --load-sa"
sudo yabai --load-sa

### start janky borders
"$HOME/.local/bin/borders_auto" &

### global settings
yabai -m config layout                       bsp
yabai -m config auto_balance                 on
yabai -m config mouse_follows_focus          off
yabai -m config focus_follows_mouse          off
yabai -m config window_origin_display        default
yabai -m config window_placement             second_child
yabai -m config window_shadow                float
yabai -m config window_animation_duration    0.0
yabai -m config window_opacity               off
yabai -m config window_opacity_duration      0.0
yabai -m config active_window_opacity        1.0
yabai -m config normal_window_opacity        1.0
yabai -m config top_padding                  4
yabai -m config bottom_padding               10
yabai -m config left_padding                 8
yabai -m config right_padding                8
yabai -m config window_gap                   14
yabai -m config insert_feedback_color        0x00FFFFFF #0xffdd383a
#yabai -m config split_ratio                 0.50
#yabai -m config auto_balance                on
yabai -m config mouse_modifier               alt
yabai -m config mouse_action1                move
yabai -m config mouse_action2                resize
yabai -m config mouse_drop_action            swap

### fix tab apps
#source "$YABAI_DIR/scripts/tab_fix"

### settings for spaces
#source "$YABAI_DIR/spacesrc"
#yabai -m rule --list

### app-specific rules
yabai -m rule --add label="manage_off__activity_monitor" app="^Activity Monitor$" manage=off
yabai -m rule --add label="manage_off__antinote" app="Antinote" manage=off
yabai -m rule --add label="manage_off__app_store" app="^App Store$" manage=off
yabai -m rule --add label="manage_off__colorslurp" app="ColorSlurp" title=".*" manage=off
yabai -m rule --add label="manage_off__dictionary" app="^Dictionary$" manage=off
yabai -m rule --add label="manage_off__digital_color_meter" title="^Digital Color Meter$" manage=off
yabai -m rule --add label="manage_off__drafts" app="^Drafts$" manage=off
yabai -m rule --add label="manage_off__kaleidoscope" app="^Kaleidoscope$" manage=off
yabai -m rule --add label="manage_off__microsoft_outlook_calendar" app="^Microsoft Outlook$" title="• Calendar •" manage=off
yabai -m rule --add label="manage_off__microsoft_teams" app="Microsoft Teams" title="^\(Meeting\|\[.*\]\).*\|" manage=off
yabai -m rule --add label="manage_off__numi" title="^Numi$" manage=off
yabai -m rule --add label="manage_off__preferences" title="^Preferences$" manage=off
yabai -m rule --add label="manage_off__quick_drafts" app="Quick Drafts" manage=off
yabai -m rule --add label="manage_off__safari_settings" app="^Safari$" title="^(General|Tabs|Passwords|Websites|Extensions|AutoFill|Search|Security|Privacy|Advanced)$" manage=off
yabai -m rule --add label="manage_off__settings" title='Settings$' manage=off
yabai -m rule --add label="manage_off__software_update" title="Software Update" manage=off
yabai -m rule --add label="manage_off__system_information" app="^System Information$" manage=off
yabai -m rule --add label="manage_off__system_settings" app="System Settings" manage=off
yabai -m rule --add label="manage_off__tot" app="Tot" manage=off
yabai -m rule --add label="manage_on__citrix" app="Citrix" manage=on

# column layout (auto-detects display width → 2/3/4 columns)
#bash "$YABAI_DIR/scripts/yabai_config_layout_cols"

