### Launch apps
# application launcher: Alfred
ctrl + alt - space : open_alfred
# change themes
ctrl + alt - d : change_theme.sh
# refresh borders
ctrl + alt - b : borders_auto
# open drafts
shift + ctrl + alt - d : open_drafts
# terminal: kitty
ctrl + alt - return : open_kitty
# broswer: Safari
shift + ctrl + alt - return : open_safari
# finder
shift + ctrl + alt - f : open_finder

### Configuration
ctrl + alt - c : skhd --reload
ctrl + alt - r : yabai --restart-service; skhd --restart-service

### Save / restore window layout
ctrl + alt - s : yabai_save
ctrl + alt + cmd - s : yabai_restore

# reconfigure column layout and rebalance
#ctrl + alt - a : yabai_config_layout_cols
ctrl + alt - a : yabai -m space --balance

# focus on window in specified direction
ctrl + alt - left : yabai -m window --focus west
ctrl + alt - down : \
    yabai -m window --focus stack.next || \
    yabai -m window --focus south || \
    yabai -m window --focus stack.first
ctrl + alt - up : \
    yabai -m window --focus stack.prev || \
    yabai -m window --focus north || \
    yabai -m window --focus stack.last
ctrl + alt - right : yabai -m window --focus east

# Move windows out of stacks or swap in specified direction
shift + ctrl + alt - left : yabai3 move west
shift + ctrl + alt - down : yabai3 move north
shift + ctrl + alt - up : yabai3 move south
shift + ctrl + alt - right : yabai3 move east
