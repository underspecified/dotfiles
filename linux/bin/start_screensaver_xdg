#!/bin/bash

CURDIR=$(dirname $0)
DOTFILES=$(realpath $CURDIR/../..)

LOCK_MIN=5
LOCK_SEC=$(($LOCK_MIN * 60))
IDLE_MIN=10
IDLE_SEC=$(($IDLE_MIN * 60))

mode=$(darkman get)
source "$DOTFILES/colors/selenized_${mode}.env"

gsettings set org.gnome.desktop.background picture-uri "file://$wallpaper"
#gsettings set org.gnome.desktop.session idle-delay $IDLE_SEC
#gsettings set org.gnome.desktop.screensaver lock-delay $LOCK_SEC

xset dpms $IDLE_SEC
GDK_BACKEND=x11 gnome-screensaver &
xautolock -time $LOCK_MIN -locker "$DOTFILES/linux/bin/lock_screen_xdg"
#sleep $LOCK_SEC
$DOTFILES/linux/bin/lock_screen_xdg
